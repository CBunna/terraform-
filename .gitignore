# Terraform providers and plugins (downloaded by terraform init)
**/.terraform/

# State files (may contain sensitive data)
*.tfstate
*.tfstate.backup

# Plan files
*.tfplan

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform lock file for providers (keep this in git)
# !.terraform.lock.hcl

# macOS
.DS_Store
